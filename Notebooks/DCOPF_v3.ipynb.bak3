    "axes[0, 1].set_ylabel(\"α*\")\n",
    "axes[0, 1].set_title(\"α* vs. hour of day\")\n",
    "\n",
    "# (c) α* vs forecast error (Pd_hat - Pd_actual)\n",
    "err = df_alpha[\"forecast_mw\"] - df_alpha[\"actual_mw\"]\n",
    "axes[1, 0].scatter(err, df_alpha[\"alpha_star\"], s=15, alpha=0.6)\n",
    "axes[1, 0].axhline(1.0, color='red', linestyle='--')\n",
