    "axes[2].axvline(1.0, color='gray', linestyle=':')\n",
    "axes[2].set_xlabel(\"Fixed α\")\n",
    "axes[2].set_ylabel(\"Mean limit violation (MW)\")\n",
    "axes[2].set_title(\"Limit violations vs fixed α\")\n",
    "axes[2].grid(True, alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
