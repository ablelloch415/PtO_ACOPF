   "source": [
    "### 4.2 Train Gradient Boosted Regressor: Covariates → α*"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 35,
   "id": "f0ac7e2b",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "α-model feature matrix: (200, 14)\n",
      "Features: ['temp_stationary', 'week', 'hour', 'day_of_month', 'day_of_week', 'is_holiday', 'lag_1', 'lag_2', 'lag_3', 'lag_4', 'lag_5', 'lag_6', 'pgbm_median_mw', 'pgbm_quantile_std']\n",
      "\n",
      "α-model train: 140   test: 60\n",
      "\n",
      "=======================================================\n",
      "  Metric                           Train         Test\n",
      "=======================================================\n",
      "  MAE                            0.00295      0.00228\n",
      "  RMSE                           0.00799      0.00505\n",
      "  R²                              0.6957       0.0000\n",
      "  Mean α* (actual)                0.9979       1.0000\n",
      "  Mean α* (predicted)             0.9979       0.9986\n",
      "=======================================================\n",
      "\n",
      "Feature importances (top 8):\n",
      "pgbm_median_mw       0.6439\n",
      "pgbm_quantile_std    0.1266\n",
      "hour                 0.0745\n",
      "lag_2                0.0641\n",
      "day_of_week          0.0285\n",
      "temp_stationary      0.0169\n",
      "lag_5                0.0142\n",
      "lag_3                0.0109\n"
     ]
    }
   ],
   "source": [
    "# =============================================================================\n",
    "# Phase 4 — Step 2: Train a GBR to predict α* from covariates.\n",
    "#\n",
    "# Uses the same feature vector as the PGBM (selected + lags), plus two\n",
    "# extra features: the PGBM median forecast and scenario spread, which\n",
    "# carry information about forecast confidence.\n",
    "#\n",
    "# Train/test split: first 70% of eval_positions for training, last 30%\n",
    "# for held-out evaluation (time-ordered, no shuffling).\n",
    "# =============================================================================\n",
    "import numpy as np\n",
    "from sklearn.ensemble import GradientBoostingRegressor\n",
    "from sklearn.metrics import mean_absolute_error, mean_squared_error, r2_score\n",
    "\n",
    "# --- Build feature matrix for the α-model ---\n",
    "# For each eval timestep, gather: (a) the same covariates from X_te,\n",
    "# (b) the PGBM median forecast, (c) the PGBM scenario std.\n",
    "alpha_features = []\n",
    "for _, row in df_alpha.iterrows():\n",
    "    t = int(row[\"t_pos\"])\n",
    "    base_feats = X_te[t]                                  # same features as PGBM\n",
    "    pgbm_mw    = pgbm_quantile_preds_mw[t, median_idx]    # median forecast (MW)\n",
    "    scen_std   = pgbm_quantile_preds_mw[t].std()           # quantile spread\n",
    "    alpha_features.append(np.concatenate([base_feats, [pgbm_mw, scen_std]]))\n",
    "\n",
    "X_alpha = np.array(alpha_features)\n",
    "y_alpha = df_alpha[\"alpha_star\"].values\n",
    "\n",
    "feature_names_alpha = (\n",
    "    feature_cols + [\"pgbm_median_mw\", \"pgbm_quantile_std\"]\n",
    ")\n",
    "print(f\"α-model feature matrix: {X_alpha.shape}\")\n",
    "print(f\"Features: {feature_names_alpha}\")\n",
    "\n",
    "# --- Time-ordered train/test split (70/30) ---\n",
    "n_alpha = len(X_alpha)\n",
    "split_alpha = int(0.7 * n_alpha)\n",
    "\n",
    "X_alpha_tr, X_alpha_te = X_alpha[:split_alpha], X_alpha[split_alpha:]\n",
    "y_alpha_tr, y_alpha_te = y_alpha[:split_alpha], y_alpha[split_alpha:]\n",
    "print(f\"\\nα-model train: {len(X_alpha_tr)}   test: {len(X_alpha_te)}\")\n",
    "\n",
    "# --- Train GBR ---\n",
    "alpha_model = GradientBoostingRegressor(\n",
    "    n_estimators=100,\n",
    "    max_depth=3,\n",
    "    learning_rate=0.05,\n",
    "    min_samples_leaf=10,\n",
    "    loss=\"squared_error\",\n",
    "    random_state=0,\n",
    ")\n",
    "alpha_model.fit(X_alpha_tr, y_alpha_tr)\n",
    "\n",
    "# --- Evaluate on held-out portion ---\n",
    "y_pred_tr = alpha_model.predict(X_alpha_tr)\n",
    "y_pred_te = alpha_model.predict(X_alpha_te)\n",
    "\n",
    "print(\"\\n\" + \"=\" * 55)\n",
    "print(f\"  {'Metric':<25} {'Train':>12} {'Test':>12}\")\n",
    "print(\"=\" * 55)\n",
    "print(f\"  {'MAE':<25} {mean_absolute_error(y_alpha_tr, y_pred_tr):>12.5f} {mean_absolute_error(y_alpha_te, y_pred_te):>12.5f}\")\n",
    "print(f\"  {'RMSE':<25} {np.sqrt(mean_squared_error(y_alpha_tr, y_pred_tr)):>12.5f} {np.sqrt(mean_squared_error(y_alpha_te, y_pred_te)):>12.5f}\")\n",
    "print(f\"  {'R²':<25} {r2_score(y_alpha_tr, y_pred_tr):>12.4f} {r2_score(y_alpha_te, y_pred_te):>12.4f}\")\n",
    "print(f\"  {'Mean α* (actual)':<25} {y_alpha_tr.mean():>12.4f} {y_alpha_te.mean():>12.4f}\")\n",
    "print(f\"  {'Mean α* (predicted)':<25} {y_pred_tr.mean():>12.4f} {y_pred_te.mean():>12.4f}\")\n",
    "print(\"=\" * 55)\n",
    "\n",
    "# --- Feature importance ---\n",
    "importances = pd.Series(\n",
    "    alpha_model.feature_importances_, index=feature_names_alpha\n",
    ").sort_values(ascending=False)\n",
    "print(\"\\nFeature importances (top 8):\")\n",
    "print(importances.head(8).round(4).to_string())"
   ]
  },
