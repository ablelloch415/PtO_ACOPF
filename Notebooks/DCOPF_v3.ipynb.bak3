    "axes[1, 0].set_xlabel(\"Forecast error (MW)\")\n",
    "axes[1, 0].set_ylabel(\"α*\")\n",
    "axes[1, 0].set_title(\"α* vs. forecast error\")\n",
    "\n",
    "# (d) SP expected cost improvement from optimal α*\n",
    "axes[1, 1].hist(df_alpha[\"sp_improvement\"], bins=40, edgecolor='black', alpha=0.7)\n",
    "axes[1, 1].axvline(0, color='red', linestyle='--')\n",
    "axes[1, 1].set_xlabel(\"SP expected cost improvement over α=1 ($/hr)\")\n",
    "axes[1, 1].set_ylabel(\"Count\")\n",
    "axes[1, 1].set_title(\n",
    "    f\"SP improvement from smart α* (mean=${df_alpha['sp_improvement'].mean():,.1f}/hr)\"\n",
    ")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "ddad0768",
