     "name": "stderr",
     "output_type": "stream",
     "text": [
      "\n"
     ]
    }
   ],
   "source": [
    "# =============================================================================\n",
    "# Phase 4 — Step 3: Rolling evaluation with covariate-dependent α.\n",
    "#\n",
    "# Identical to the Phase 2 evaluation loop except:\n",
    "#   participation_t = α(t) · (Pg_max / Pg_max.sum())\n",
    "# where α(t) = alpha_model.predict(features_at_t), clipped to [0.90, 1.10].\n",
    "#\n",
    "# The point forecast Pd_hat_t is UNCHANGED. α controls only how aggressively\n",
    "# generators respond to real-time imbalance in Stage 2, keeping the Stage-1\n",
    "# forecast and scenario distribution internally consistent.\n",
    "# =============================================================================\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from tqdm import tqdm\n",
    "\n",
    "ALPHA_LO, ALPHA_HI = 0.90, 1.10\n",
    "\n",
    "base_participation = Pg_max / Pg_max.sum()\n",
    "rng_p4_eval = np.random.default_rng(42)\n",
    "\n",
    "records_p4 = []\n",
    "failed_p4  = []\n",
    "\n",
    "for t_pos in tqdm(eval_positions, desc=\"Phase 4: smart-α → DC-OPF\"):\n",
    "    try:\n",
    "        # --- Predict α(t) from covariates ---\n",
    "        base_feats = X_te[t_pos]\n",
    "        pgbm_mw    = pgbm_quantile_preds_mw[t_pos, median_idx]\n",
    "        scen_std   = pgbm_quantile_preds_mw[t_pos].std()\n",
    "        x_alpha_t  = np.concatenate([base_feats, [pgbm_mw, scen_std]]).reshape(1, -1)\n",
    "\n",
    "        alpha_t = float(alpha_model.predict(x_alpha_t)[0])\n",
    "        alpha_t = np.clip(alpha_t, ALPHA_LO, ALPHA_HI)\n",
    "\n",
    "        # --- Scale the participation vector; forecast stays unscaled ---\n",
    "        Pd_hat_t      = pgbm_forecast_at(t_pos)\n",
    "        participation_t = alpha_t * base_participation   # sums to alpha_t, not 1\n",
    "\n",
    "        scenarios_t = sample_pgbm_scenarios(t_pos, N_SCENARIOS_P4, rng_p4_eval)\n",
    "        actual_Pd_t = pgbm_actual_at(t_pos)\n",
    "\n",
    "        # --- Solve stochastic DC-OPF with scaled participation ---\n",
    "        res = build_and_solve_fixed_alpha(\n",
    "            Pd_hat_t, scenarios_t, participation_t, verbose=False\n",
    "        )\n",
    "        rlz = realized_cost(res[\"Pg\"], participation_t, actual_Pd_t, Pd_hat_t)\n",
    "\n",
    "        records_p4.append({\n",
    "            \"t_pos\":             int(t_pos),\n",
    "            \"timestamp\":         idx_te[t_pos],\n",
    "            \"hour\":              idx_te[t_pos].hour,\n",
    "            \"dow\":               idx_te[t_pos].dayofweek,\n",
    "            \"alpha_used\":        alpha_t,\n",
    "            \"pgbm_mw\":           float(Pd_hat_t.sum()),\n",
    "            \"actual_mw\":         float(actual_Pd_t.sum()),\n",
    "            \"forecast_error\":    float(Pd_hat_t.sum() - actual_Pd_t.sum()),\n",
    "            \"sp_expected_cost\":  res[\"total_cost\"],\n",
    "            \"sp_stage1_cost\":    res[\"stage1_cost\"],\n",
    "            \"Pg_total\":          float(res[\"Pg\"].sum()),\n",
    "            \"realized_total\":    rlz[\"total\"],\n",
    "            \"realized_delta\":    rlz[\"delta\"],\n",
    "            \"realized_shed\":     rlz[\"shed\"],\n",
    "            \"limit_viol_mw\":     rlz[\"limit_viol\"],\n",
    "        })\n",
    "    except Exception as e:\n",
    "        failed_p4.append((int(t_pos), str(e)))\n",
    "\n",
    "results_p4 = pd.DataFrame(records_p4)\n",
    "print(f\"\\nSolved: {len(results_p4)}/{len(eval_positions)}   Failed: {len(failed_p4)}\")\n",
    "if failed_p4:\n",
    "    print(\"First 3 failures:\", failed_p4[:3])\n",
    "\n",
    "# --- Summary ---\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "print(\"Phase 4: Smart-α participation → stochastic DC-OPF summary\")\n",
    "print(\"=\" * 60)\n",
    "\n",
    "print(f\"\\nParticipation scalar α:\")\n",
    "print(f\"  Mean α used:             {results_p4['alpha_used'].mean():>10.4f}\")\n",
    "print(f\"  Std α used:              {results_p4['alpha_used'].std():>10.4f}\")\n",
    "print(f\"  Min / Max:               {results_p4['alpha_used'].min():.4f} / {results_p4['alpha_used'].max():.4f}\")\n",
    "\n",
    "print(f\"\\nForecast quality (unscaled PGBM forecast):\")\n",
    "print(f\"  MAE:                     {results_p4['forecast_error'].abs().mean():>10,.1f} MW\")\n",
    "print(f\"  Bias:                    {results_p4['forecast_error'].mean():>10,.1f} MW\")\n",
    "\n",
    "print(f\"\\nCost outputs:\")\n",
    "print(f\"  E[SP expected cost]:     ${results_p4['sp_expected_cost'].mean():>12,.2f}/hr\")\n",
    "print(f\"  E[realized cost]:        ${results_p4['realized_total'].mean():>12,.2f}/hr\")\n",
    "gap = (results_p4['realized_total'] - results_p4['sp_expected_cost']).mean()\n",
    "print(f\"  Calibration gap:         ${gap:>12,.2f}/hr\")\n",
    "\n",
    "print(f\"\\nRealized performance:\")\n",
    "print(f\"  Avg load shed:           {results_p4['realized_shed'].mean():>10,.2f} MW\")\n",
    "print(f\"  Avg limit violation:     {results_p4['limit_viol_mw'].mean():>10,.2f} MW\")\n"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "4da472fb",
   "metadata": {},
   "source": [
    "## Phase 5: Fixed (Non-Covariate) Scaling Factor\n",
    "\n",
    "**Idea:** A simpler baseline for Phase 4 — use a single, fixed scaling factor `α` applied uniformly to every timestep regardless of covariates. Sweep `α ∈ [0.90, 1.10]`, evaluate each on the full evaluation set, and pick the best one. This answers the question: *does the covariate-dependent α from Phase 4 actually add value over just always over/under-predicting by a constant amount?*"
   ]
  },
  {
   "cell_type": "markdown",
