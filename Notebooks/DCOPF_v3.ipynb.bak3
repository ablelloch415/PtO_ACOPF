    "# =============================================================================\n",
    "# Grand comparison plots\n",
    "# =============================================================================\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "\n",
    "fig, axes = plt.subplots(2, 2, figsize=(15, 11))\n",
    "\n",
    "# Collect phase info for plotting\n",
    "phase_labels   = [\"Ph.2\\n(α=1)\", f\"Ph.5\\n(α={alpha_best:.3f})\", \"Ph.4\\n(smart α)\"]\n",
    "realized_means = [grand[\"p2_realized\"].mean(), grand[\"p5_realized\"].mean(),\n",
    "                  grand[\"p4_realized\"].mean()]\n",
    "shed_means     = [grand[\"p2_shed\"].mean(), grand[\"p5_shed\"].mean(),\n",
    "                  grand[\"p4_shed\"].mean()]\n",
    "viol_means     = [grand[\"p2_viol\"].mean(), grand[\"p5_viol\"].mean(),\n",
    "                  grand[\"p4_viol\"].mean()]\n",
    "colors         = [\"steelblue\", \"orange\", \"green\"]\n",
    "\n",
    "if has_p3:\n",
    "    phase_labels.insert(1, \"Ph.3\\n(NN+SPO)\")\n",
    "    realized_means.insert(1, grand[\"p3_realized\"].mean())\n",
    "    shed_means.insert(1, grand[\"p3_shed\"].mean())\n",
    "    viol_means.insert(1, grand[\"p3_viol\"].mean())\n",
    "    colors.insert(1, \"mediumpurple\")\n",
    "\n",
    "if has_p6:\n",
    "    phase_labels.append(\"Ph.6\\n(SPO++PGBM)\")\n",
    "    realized_means.append(grand[\"p6_realized\"].mean())\n",
    "    shed_means.append(grand[\"p6_shed\"].mean())\n",
    "    viol_means.append(grand[\"p6_viol\"].mean())\n",
    "    colors.append(\"crimson\")\n",
    "\n",
    "# (a) Bar chart: mean realized cost\n",
    "bars = axes[0, 0].bar(phase_labels, realized_means, color=colors, edgecolor=\"black\", alpha=0.8)\n",
    "axes[0, 0].set_ylabel(\"Mean realized cost ($/hr)\")\n",
    "axes[0, 0].set_title(\"Realized Cost by Phase\")\n",
    "for bar, val in zip(bars, realized_means):\n",
    "    axes[0, 0].text(bar.get_x() + bar.get_width()/2, bar.get_height(),\n",
    "                    f\"${val:,.0f}\", ha='center', va='bottom', fontsize=9)\n",
    "\n",
    "# (b) Bar chart: mean load shed\n",
    "bars = axes[0, 1].bar(phase_labels, shed_means, color=colors, edgecolor=\"black\", alpha=0.8)\n",
    "axes[0, 1].set_ylabel(\"Mean load shed (MW)\")\n",
    "axes[0, 1].set_title(\"Load Shed by Phase\")\n",
    "for bar, val in zip(bars, shed_means):\n",
    "    axes[0, 1].text(bar.get_x() + bar.get_width()/2, bar.get_height(),\n",
    "                    f\"{val:.2f}\", ha='center', va='bottom', fontsize=9)\n",
    "\n",
    "# (c) Phase 4 vs Phase 5 scatter\n",
    "axes[1, 0].scatter(grand[\"p5_realized\"], grand[\"p4_realized\"], s=15, alpha=0.6)\n",
    "lo = min(grand[\"p5_realized\"].min(), grand[\"p4_realized\"].min())\n",
    "hi = max(grand[\"p5_realized\"].max(), grand[\"p4_realized\"].max())\n",
    "axes[1, 0].plot([lo, hi], [lo, hi], 'r--', label=\"equal cost\")\n",
    "axes[1, 0].set_xlabel(f\"Ph.5 realized cost (fixed α={alpha_best:.3f})\")\n",
    "axes[1, 0].set_ylabel(\"Ph.4 realized cost (smart α)\")\n",
    "axes[1, 0].set_title(\"Smart α vs Fixed α (per timestep)\")\n",
    "axes[1, 0].legend()\n",
    "\n",
    "# (d) Ph.6 (SPO++PGBM) vs Ph.2 (MSE+PGBM) scatter — shows SPO+ value\n",
    "if has_p6:\n",
    "    axes[1, 1].scatter(grand[\"p2_realized\"], grand[\"p6_realized\"],\n",
    "                       s=15, alpha=0.6, color=\"crimson\")\n",
    "    lo2 = min(grand[\"p2_realized\"].min(), grand[\"p6_realized\"].min())\n",
    "    hi2 = max(grand[\"p2_realized\"].max(), grand[\"p6_realized\"].max())\n",
    "    axes[1, 1].plot([lo2, hi2], [lo2, hi2], 'r--', label=\"equal cost\")\n",
    "    axes[1, 1].set_xlabel(\"Ph.2 realized cost (MSE, α=1)\")\n",
    "    axes[1, 1].set_ylabel(\"Ph.6 realized cost (SPO++PGBM, α=1)\")\n",
    "    axes[1, 1].set_title(\"SPO++PGBM vs MSE+PGBM (per timestep)\\n\"\n",
    "                         f\"(SPO+ mean advantage: ${grand['p6_vs_p2'].mean():,.2f}/hr)\")\n",
    "    axes[1, 1].legend()\n",
    "else:\n",
    "    # Fall back to the original hourly smart-α advantage plot\n",
    "    hourly_adv = grand.groupby(\"hour\")[\"p4_vs_p5\"].mean()\n",
    "    bar_colors = [\"green\" if v > 0 else \"salmon\" for v in hourly_adv.values]\n",
    "    axes[1, 1].bar(hourly_adv.index, hourly_adv.values, color=bar_colors,\n",
    "                   edgecolor=\"black\", alpha=0.7)\n",
    "    axes[1, 1].axhline(0, color='black', linewidth=0.8)\n",
    "    axes[1, 1].set_xlabel(\"Hour of day\")\n",
    "    axes[1, 1].set_ylabel(\"Advantage of smart α ($/hr)\")\n",
    "    axes[1, 1].set_title(\"Smart α advantage over fixed α by hour\\n(green = smart α saves money)\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n"
   ]
  }
