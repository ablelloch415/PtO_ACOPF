      " 0.920         93,118.19      89,540.63        0.00        0.19   200.0\n",
      " 0.930         93,013.73      89,421.90        0.00        0.19   200.0\n",
      " 0.940         92,911.47      89,303.18        0.00        0.19   200.0\n",
      " 0.950         92,812.86      89,184.45        0.00        0.19   200.0 <<<\n",
      " 0.960         92,851.85      89,106.44        0.01        0.19   199.0\n",
      " 0.970         93,015.67      88,946.99        0.04        0.19   200.0\n",
      " 0.980         93,524.66      89,072.66        0.07        0.22   200.0\n",
