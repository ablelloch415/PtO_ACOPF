   "source": [
    "# =============================================================================\n",
    "# Phase 6 — Step 2: Rolling evaluation.\n",
    "#\n",
    "# Point forecast:   SPO+-trained NN  (net_p6)\n",
    "# Scenario set:     PGBM quantile CDF samples  (sample_pgbm_scenarios)\n",
    "# Participation:    α=1 capacity-weighted  (same as Phase 2)\n",
    "#\n",
    "# This isolates the contribution of SPO+ vs MSE in the predict step while\n",
    "# keeping everything else identical to Phase 2.\n",
    "# =============================================================================\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import torch\n",
    "from tqdm import tqdm\n",
    "from gurobipy import GurobiError\n",
    "\n",
    "# Test-set trend + seasonal offset (reuse mw_offset_nn if it exists, else recompute)\n",
    "try:\n",
    "    mw_offset_p6 = mw_offset_nn   # built in Phase 3\n",
    "except NameError:\n",
    "    mw_offset_p6 = (\n",
    "        load_trend_5m_te.reindex(idx_te).values\n",
    "        + sum(s.reindex(idx_te).values for s in load_seasons_5m_te.values())\n",
    "    )\n",
    "\n",
    "alpha_p6_participation = Pg_max / Pg_max.sum()   # α=1 capacity-weighted\n",
    "\n",
    "def p6_forecast_at(t_pos):\n",
    "    \"\"\"SPO+-trained NN point forecast → nodal MW.\"\"\"\n",
    "    x = torch.tensor(X_te_sc_p6[t_pos: t_pos + 1], dtype=torch.float32)\n",
    "    with torch.no_grad():\n",
    "        pred_stat = net_p6(x).item()\n",
    "    pred_mw = pred_stat * load_scaler.scale_[0] + load_scaler.mean_[0] + mw_offset_p6[t_pos]\n",
    "    return pred_mw * (NODAL_BASE_MW / MEDIAN_LOAD_TRAIN)   # (N_BUS,)\n",
    "\n",
    "def p6_actual_at(t_pos):\n",
    "    \"\"\"Realized nodal demand (same as pgbm_actual_at).\"\"\"\n",
    "    actual_mw = (\n",
    "        y_te[t_pos] * load_scaler.scale_[0]\n",
    "        + load_scaler.mean_[0]\n",
    "        + mw_offset_p6[t_pos]\n",
    "    )\n",
    "    return actual_mw * (NODAL_BASE_MW / MEDIAN_LOAD_TRAIN)\n",
    "\n",
    "N_SCENARIOS_P6_EVAL = 100\n",
    "RNG_P6_EVAL = np.random.default_rng(42)\n",
    "\n",
    "records_p6 = []\n",
    "failed_p6  = []\n",
    "\n",
    "for t_pos in tqdm(eval_positions, desc=\"Phase 6: SPO+ NN + PGBM scenarios → DC-OPF\"):\n",
    "    try:\n",
    "        Pd_hat_t    = p6_forecast_at(t_pos)\n",
    "        # PGBM quantile CDF scenarios — same function as Phases 2/4/5\n",
    "        scenarios_t = sample_pgbm_scenarios(t_pos, N_SCENARIOS_P6_EVAL, RNG_P6_EVAL)\n",
    "        actual_Pd_t = p6_actual_at(t_pos)\n",
    "\n",
    "        res = build_and_solve_fixed_alpha(\n",
    "            Pd_hat_t, scenarios_t, alpha_p6_participation, verbose=False\n",
    "        )\n",
    "        rlz = realized_cost(res[\"Pg\"], alpha_p6_participation, actual_Pd_t, Pd_hat_t)\n",
    "\n",
    "        records_p6.append({\n",
    "            \"t_pos\":             int(t_pos),\n",
    "            \"timestamp\":         idx_te[t_pos],\n",
    "            \"hour\":              idx_te[t_pos].hour,\n",
    "            \"dow\":               idx_te[t_pos].dayofweek,\n",
    "            \"p6_mw\":             float(Pd_hat_t.sum()),\n",
    "            \"p6_scen_mean\":      float(scenarios_t.sum(axis=1).mean()),\n",
    "            \"p6_scen_std\":       float(scenarios_t.sum(axis=1).std()),\n",
    "            \"actual_mw\":         float(actual_Pd_t.sum()),\n",
    "            \"forecast_error\":    float(Pd_hat_t.sum() - actual_Pd_t.sum()),\n",
    "            \"sp_expected_cost\":  res[\"total_cost\"],\n",
    "            \"sp_stage1_cost\":    res[\"stage1_cost\"],\n",
    "            \"Pg_total\":          float(res[\"Pg\"].sum()),\n",
    "            \"realized_total\":    rlz[\"total\"],\n",
    "            \"realized_delta\":    rlz[\"delta\"],\n",
    "            \"realized_shed\":     rlz[\"shed\"],\n",
    "            \"limit_viol_mw\":     rlz[\"limit_viol\"],\n",
    "        })\n",
    "    except (GurobiError, RuntimeError) as e:\n",
    "        failed_p6.append((int(t_pos), str(e)))\n",
    "\n",
    "# What is the raw NN output?\n",
    "import torch\n",
    "for t in [0, 105, 210]:\n",
    "    x = torch.tensor(X_te_sc_p6[t:t+1], dtype=torch.float32)\n",
    "    with torch.no_grad():\n",
    "        raw = net_p6(x).item()\n",
    "    print(f\"t={t:5d}  raw NN output (stationary): {raw:.4f}\")\n",
    "\n",
    "# What does it look like before SPO+ broke it? Check the network weights.\n",
    "total_norm = sum(p.norm().item() for p in net_p6.parameters())\n",
    "print(f\"\\nTotal parameter norm: {total_norm:.2f}\")\n",
    "print(\"(Healthy network: ~10-100. Diverged network: 1000+)\")\n",
    "\n",
    "# What was the MSE warmup final loss?\n",
    "# (If you don't have it scrolled up: re-run the training cell and watch.)\n",
    "\n",
    "results_p6 = pd.DataFrame(records_p6)\n",
    "print(f\"\\nSolved: {len(results_p6)}/{len(eval_positions)}   Failed: {len(failed_p6)}\")\n",
    "if failed_p6:\n",
    "    print(\"First 3 failures:\", failed_p6[:3])\n",
    "\n",
    "print(\"\\n\" + \"=\" * 60)\n",
    "print(\"Phase 6: SPO+ NN forecast + PGBM scenarios → DC-OPF\")\n",
    "print(\"=\" * 60)\n",
    "print(f\"  MAE:                     {results_p6['forecast_error'].abs().mean():>10,.1f} MW\")\n",
    "print(f\"  Bias:                    {results_p6['forecast_error'].mean():>10,.1f} MW\")\n",
    "print(f\"  Avg PGBM scenario std:   {results_p6['p6_scen_std'].mean():>10,.1f} MW\")\n",
    "print(f\"  E[SP expected cost]:     ${results_p6['sp_expected_cost'].mean():>12,.2f}/hr\")\n",
    "print(f\"  E[realized cost]:        ${results_p6['realized_total'].mean():>12,.2f}/hr\")\n",
    "gap_p6 = (results_p6['realized_total'] - results_p6['sp_expected_cost']).mean()\n",
    "print(f\"  Calibration gap:         ${gap_p6:>12,.2f}/hr\")\n",
    "print(f\"  Avg load shed:           {results_p6['realized_shed'].mean():>10,.2f} MW\")\n",
    "print(f\"  Avg limit violation:     {results_p6['limit_viol_mw'].mean():>10,.2f} MW\")\n"
   ]
  },
