   "source": [
    "# =============================================================================\n",
    "# Phase 6 — Step 1: Train a neural net with SPO+ loss using PGBM scenarios.\n",
    "# HARDENED VERSION: fixes training divergence observed in first attempt.\n",
    "# =============================================================================\n",
    "import torch\n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "import numpy as np\n",
    "from tqdm import tqdm\n",
    "from sklearn.preprocessing import StandardScaler as FeatScaler\n",
    "\n",
    "# ── 1. Standardize features ──────────────────────────────────────────────────\n",
    "feat_scaler_p6 = FeatScaler().fit(X_tr)\n",
    "X_tr_sc_p6     = feat_scaler_p6.transform(X_tr)\n",
    "X_te_sc_p6     = feat_scaler_p6.transform(X_te)\n",
    "\n",
    "# ── 2. Subsample training instances ──────────────────────────────────────────\n",
    "import pandas as pd\n",
    "\n",
    "N_SPO_SAMPLES_P6 = 500\n",
    "RNG_P6_SUB       = np.random.default_rng(77)\n",
    "\n",
    "hours_tr_p6 = pd.DatetimeIndex(train_data.index).hour\n",
    "unique_hours_p6 = np.unique(hours_tr_p6)\n",
    "samples_per_hour_p6 = max(1, N_SPO_SAMPLES_P6 // len(unique_hours_p6))\n",
    "\n",
    "sub_idx_p6 = []\n",
    "for h in unique_hours_p6:\n",
    "    mask = np.where(hours_tr_p6 == h)[0]\n",
    "    n_pick = min(samples_per_hour_p6, len(mask))\n",
    "    sub_idx_p6.extend(RNG_P6_SUB.choice(mask, size=n_pick, replace=False).tolist())\n",
    "RNG_P6_SUB.shuffle(sub_idx_p6)\n",
    "sub_idx_p6 = sorted(sub_idx_p6[:N_SPO_SAMPLES_P6])\n",
    "\n",
    "X_tr_spo_p6 = X_tr_sc_p6[sub_idx_p6]\n",
    "y_tr_spo_p6 = y_tr[sub_idx_p6]\n",
    "\n",
    "try:\n",
    "    offset_spo_p6 = mw_offset_per_t_train[sub_idx_p6]\n",
    "except NameError:\n",
    "    idx_tr_p6 = train_data.index\n",
    "    _offset_tr = (\n",
    "        load_trend_5m_tr.reindex(idx_tr_p6).values\n",
    "        + sum(s.reindex(idx_tr_p6).values for s in load_seasons_5m_tr.values())\n",
    "    )\n",
    "    offset_spo_p6 = _offset_tr[sub_idx_p6]\n",
    "\n",
    "print(f\"SPO+ (P6) training subset: {len(sub_idx_p6)} / {len(X_tr)} samples\")\n",
    "\n",
    "# ── 3. Scenario helper ───────────────────────────────────────────────────────\n",
    "N_SCEN_P6_TRAIN = 20\n",
    "RNG_P6_SCEN     = np.random.default_rng(88)\n",
    "\n",
    "def _make_train_scenarios_p6(i_in_sub, n_scen=N_SCEN_P6_TRAIN):\n",
    "    true_mw = (\n",
    "        y_tr_spo_p6[i_in_sub] * load_scaler.scale_[0]\n",
    "        + load_scaler.mean_[0]\n",
    "        + offset_spo_p6[i_in_sub]\n",
    "    )\n",
    "    true_mw = max(true_mw, 0.0)\n",
    "    noise_std = true_mw * 0.05\n",
    "    caiso_scen = true_mw + RNG_P6_SCEN.normal(0, noise_std, size=n_scen)\n",
    "    caiso_scen = np.maximum(caiso_scen, 0)\n",
    "    return np.outer(caiso_scen, NODAL_BASE_MW / MEDIAN_LOAD_TRAIN)\n",
    "\n",
    "# ── 4. Neural net definition ─────────────────────────────────────────────────\n",
    "class SPONetP6(nn.Module):\n",
    "    def __init__(self, in_features):\n",
    "        super().__init__()\n",
    "        self.net = nn.Sequential(\n",
    "            nn.Linear(in_features, 64),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(64, 32),\n",
    "            nn.ReLU(),\n",
    "            nn.Linear(32, 1),\n",
    "        )\n",
    "    def forward(self, x):\n",
    "        return self.net(x).squeeze()\n",
    "\n",
    "net_p6 = SPONetP6(X_tr_spo_p6.shape[1])\n",
    "\n",
    "X_tensor_p6 = torch.tensor(X_tr_spo_p6, dtype=torch.float32)\n",
    "y_tensor_p6 = torch.tensor(y_tr_spo_p6, dtype=torch.float32)\n",
    "scaler_mean_p6  = load_scaler.mean_[0]\n",
    "scaler_scale_p6 = load_scaler.scale_[0]\n",
    "\n",
    "# ── 5. MSE warm-up ───────────────────────────────────────────────────────────\n",
    "MSE_WARMUP_P6 = 10\n",
    "SPO_EPOCHS_P6 = 10\n",
    "ALPHA_P6_FIXED = Pg_max / Pg_max.sum()\n",
    "\n",
    "# ### CHANGED ### — separate optimizers for MSE warmup vs SPO+ fine-tuning\n",
    "# MSE uses a normal lr; SPO+ needs a much smaller lr due to larger gradients.\n",
    "optimizer_mse = optim.Adam(net_p6.parameters(), lr=1e-3)\n",
    "\n",
    "mse_loss_fn_p6 = nn.MSELoss()\n",
    "loader_p6 = torch.utils.data.DataLoader(\n",
    "    torch.utils.data.TensorDataset(X_tensor_p6, y_tensor_p6),\n",
    "    batch_size=128, shuffle=True\n",
    ")\n",
    "\n",
    "print(f\"\\nMSE warm-up ({MSE_WARMUP_P6} epochs)...\")\n",
    "net_p6.train()\n",
    "for ep in range(MSE_WARMUP_P6):\n",
    "    ep_loss = 0.0\n",
    "    for xb, yb in loader_p6:\n",
    "        optimizer_mse.zero_grad()\n",
    "        loss = mse_loss_fn_p6(net_p6(xb).squeeze(), yb)\n",
    "        loss.backward()\n",
    "        optimizer_mse.step()\n",
    "        ep_loss += loss.item() * len(xb)\n",
    "    if (ep + 1) % 5 == 0 or ep == 0:\n",
    "        print(f\"  epoch {ep+1}/{MSE_WARMUP_P6}  MSE={ep_loss/len(X_tensor_p6):.5f}\")\n",
    "print(\"MSE warm-up done — switching to SPO+ loss\\n\")\n",
    "\n",
    "# ### CHANGED ### — sanity check after warmup\n",
    "with torch.no_grad():\n",
    "    sample_out = net_p6(X_tensor_p6[:20])\n",
    "    print(f\"Post-warmup NN output stats: \"\n",
    "          f\"mean={sample_out.mean():.3f}, std={sample_out.std():.3f}, \"\n",
    "          f\"min={sample_out.min():.3f}, max={sample_out.max():.3f}\")\n",
    "    print(\"(Should be ~O(1) — these are standardized residuals)\\n\")\n",
    "\n",
    "# ### CHANGED ### — smaller lr + new optimizer for SPO+ phase\n",
    "optimizer_spo = optim.Adam(net_p6.parameters(), lr=1e-5)\n",
    "\n",
    "# ### CHANGED ### — normalization scale for SPO+ gradient\n",
    "# LMPs are in $/MWh; typical values 20-100, with VOLL-driven spikes to 10000.\n",
    "# Dividing by VOLL brings the gradient into O(1) range.\n",
    "GRAD_NORMALIZATION_P6 = 10_000.0   # = VOLL\n",
    "\n",
    "# ### CHANGED ### — gradient clipping threshold\n",
    "MAX_GRAD_NORM_P6 = 1.0\n",
    "\n",
    "nodal_ratio_p6 = NODAL_BASE_MW / MEDIAN_LOAD_TRAIN\n",
    "Pg_total_max_p6 = Pg_max.sum()\n",
    "Pg_total_min_p6 = Pg_min.sum()\n",
    "\n",
    "def _clamp_demand_p6(Pd):\n",
    "    Pd = np.maximum(Pd, 0)\n",
    "    total = Pd.sum()\n",
    "    if total > Pg_total_max_p6 * 0.95:\n",
    "        Pd = Pd * (Pg_total_max_p6 * 0.95 / total)\n",
    "    elif total > 0 and total < Pg_total_min_p6 * 1.05:\n",
    "        Pd = Pd * (Pg_total_min_p6 * 1.05 / total)\n",
    "    return Pd\n",
    "\n",
    "net_p6.train()\n",
    "for epoch in range(SPO_EPOCHS_P6):\n",
    "    print(f\"SPO+ epoch {epoch+1}/{SPO_EPOCHS_P6}\")\n",
    "    n_skipped = 0\n",
    "    n_diverge_guard = 0   ### CHANGED ###\n",
    "    epoch_grad_norms = []  ### CHANGED ### — for monitoring\n",
    "\n",
    "    for i in tqdm(range(len(X_tensor_p6))):\n",
    "        x_i = X_tensor_p6[i]\n",
    "\n",
    "        # --- Forward pass ---\n",
    "        pred_stat = net_p6(x_i)\n",
    "\n",
    "        # ### CHANGED ### — early divergence guard\n",
    "        # If the NN starts producing absurd outputs, skip this sample\n",
    "        # rather than feeding garbage into the LP oracle.\n",
    "        if abs(pred_stat.item()) > 10.0:\n",
    "            n_diverge_guard += 1\n",
    "            continue\n",
    "\n",
    "        pred_caiso_mw = pred_stat * scaler_scale_p6 + scaler_mean_p6 + offset_spo_p6[i]\n",
    "        Pd_hat = pred_caiso_mw * torch.tensor(nodal_ratio_p6, dtype=torch.float32)\n",
    "\n",
    "        true_caiso_mw = (\n",
    "            y_tr_spo_p6[i] * scaler_scale_p6 + scaler_mean_p6 + offset_spo_p6[i]\n",
    "        )\n",
    "        Pd_true_np = _clamp_demand_p6(true_caiso_mw * nodal_ratio_p6)\n",
    "\n",
    "        with torch.no_grad():\n",
    "            Pd_hat_np   = _clamp_demand_p6(Pd_hat.detach().numpy())\n",
    "            scenarios_i = _make_train_scenarios_p6(i)\n",
    "\n",
    "            try:\n",
    "                res_true  = build_and_solve_fixed_alpha(Pd_true_np, scenarios_i, ALPHA_P6_FIXED)\n",
    "                w_true    = res_true[\"LMP_1\"]\n",
    "\n",
    "                Pd_spo_np = _clamp_demand_p6(2 * Pd_hat_np - Pd_true_np)\n",
    "                res_spo   = build_and_solve_fixed_alpha(Pd_spo_np, scenarios_i, ALPHA_P6_FIXED)\n",
    "                w_spo     = res_spo[\"LMP_1\"]\n",
    "            except Exception:\n",
    "                n_skipped += 1\n",
    "                continue\n",
    "\n",
    "            # ### CHANGED ### — normalize gradient by VOLL scale\n",
    "            g = 2.0 * (w_true - w_spo) / GRAD_NORMALIZATION_P6\n",
    "            g_tensor = torch.tensor(g, dtype=torch.float32)\n",
    "\n",
    "        # --- Backprop ---\n",
    "        optimizer_spo.zero_grad()\n",
    "        loss_surrogate = torch.sum(Pd_hat * g_tensor)\n",
    "        loss_surrogate.backward()\n",
    "\n",
    "        # ### CHANGED ### — gradient clipping to prevent blowup\n",
    "        grad_norm = torch.nn.utils.clip_grad_norm_(net_p6.parameters(), MAX_GRAD_NORM_P6)\n",
    "        epoch_grad_norms.append(grad_norm.item())\n",
    "\n",
    "        optimizer_spo.step()\n",
    "\n",
    "    # ### CHANGED ### — monitoring output\n",
    "    print(f\"  Skipped {n_skipped} infeasible | {n_diverge_guard} divergence-guarded\")\n",
    "    if epoch_grad_norms:\n",
    "        print(f\"  Grad norm — mean: {np.mean(epoch_grad_norms):.3f}, \"\n",
    "              f\"max: {np.max(epoch_grad_norms):.3f} (pre-clip)\")\n",
    "\n",
    "    # ### CHANGED ### — per-epoch sanity check\n",
    "    with torch.no_grad():\n",
    "        sample_out = net_p6(X_tensor_p6[:20])\n",
    "        print(f\"  NN output stats: mean={sample_out.mean():.3f}, \"\n",
    "              f\"std={sample_out.std():.3f}, \"\n",
    "              f\"max_abs={sample_out.abs().max():.3f}\")\n",
    "\n",
    "    # ### CHANGED ### — abort if diverged\n",
    "    param_norm = sum(p.norm().item() for p in net_p6.parameters())\n",
    "    if param_norm > 500 or sample_out.abs().max() > 50:\n",
    "        print(f\"\\n  ⚠️  Training diverged (param_norm={param_norm:.1f}). Aborting SPO+ phase.\")\n",
    "        break\n",
    "\n",
    "net_p6.eval()\n",
    "print(\"\\nPhase 6 SPO+ training complete.\")\n",
    "\n",
    "# Final diagnostic\n",
    "with torch.no_grad():\n",
    "    final_out = net_p6(X_tensor_p6)\n",
    "print(f\"Final NN output range: [{final_out.min():.3f}, {final_out.max():.3f}]\")\n",
    "print(f\"Final parameter norm:  {sum(p.norm().item() for p in net_p6.parameters()):.2f}\")"
   ]
  },
