    "## Phase 3: Smart Predict Then Optimize (Using Neural Net and SPO Loss)\n",
    "references: elmachtoub SPTO"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "8853e27e",
   "metadata": {},
   "source": [
    "### 3.2 Train Simple Neural Net Using SPO Loss"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 29,
   "id": "659180d1",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "mw_offset_per_t_train shape: (84044,)\n",
      "  range: [12204.3, 52406.1] MW\n",
      "training_scenarios shape: (84044, 10, 118)\n",
      "  noise_std: 279.6 MW\n",
      "  per-instance scenario spread (mean std): 44.9 MW\n"
     ]
    }
   ],
   "source": [
    "# =============================================================================\n",
    "# Phase 3 setup: compute mw_offset_per_t_train and training_scenarios\n",
    "#\n",
    "# mw_offset_per_t_train: trend + seasonal offset for each training timestamp,\n",
    "#   analogous to mw_offset_per_t (test set) built in cell 32.\n",
    "#\n",
    "# training_scenarios: (N_train, N_SCEN, N_BUS) array of nodal demand scenarios\n",
    "#   for SPO+ training.  Uses a simple approach: for each training instance,\n",
    "#   perturb the true load by Gaussian noise calibrated to the training residual\n",
    "#   std, then scale to nodal MW.  This is cheap and avoids needing PGBM\n",
    "#   quantile predictions on the training set.\n",
    "# =============================================================================\n",
    "import numpy as np\n",
    "\n",
    "# --- 1. Training-set trend + seasonal offset (same formula as cell 32, but for train) ---\n",
    "idx_tr = train_data.index\n",
    "\n",
    "mw_offset_per_t_train = (\n",
    "    load_trend_5m_tr.reindex(idx_tr).values\n",
    "    + sum(s.reindex(idx_tr).values for s in load_seasons_5m_tr.values())\n",
    ")\n",
    "print(f\"mw_offset_per_t_train shape: {mw_offset_per_t_train.shape}\")\n",
    "print(f\"  range: [{mw_offset_per_t_train.min():.1f}, {mw_offset_per_t_train.max():.1f}] MW\")\n",
    "\n",
    "# --- 2. Training scenarios via Gaussian perturbation of true load ---\n",
    "N_SCEN_TRAIN = 10   # keep small for speed (SPO+ already does 1-sample SGD per instance)\n",
    "RNG_TRAIN    = np.random.default_rng(123)\n",
    "\n",
    "# Reconstruct true CAISO MW for each training instance\n",
    "true_resid_mw_tr = load_scaler.inverse_transform(y_tr.reshape(-1, 1)).ravel()\n",
    "true_caiso_mw_tr = true_resid_mw_tr + mw_offset_per_t_train\n",
    "\n",
    "# Perturbation scale: std of the PGBM training residuals (or load residuals)\n",
    "noise_std = true_caiso_mw_tr.std() * 0.05   # 5% of load std as scenario spread\n",
    "\n",
    "# Generate (N_train, N_SCEN_TRAIN) CAISO MW scenarios\n",
    "caiso_scenarios = (\n",
    "    true_caiso_mw_tr[:, None]\n",
    "    + RNG_TRAIN.normal(0, noise_std, size=(len(true_caiso_mw_tr), N_SCEN_TRAIN))\n",
    ")\n",
    "caiso_scenarios = np.maximum(caiso_scenarios, 0)  # no negative load\n",
    "\n",
    "# Convert to nodal: (N_train, N_SCEN_TRAIN, N_BUS)\n",
    "scaling = caiso_scenarios / MEDIAN_LOAD_TRAIN       # (N_train, N_SCEN)\n",
    "training_scenarios = scaling[:, :, None] * NODAL_BASE_MW[None, None, :]\n",
    "\n",
    "print(f\"training_scenarios shape: {training_scenarios.shape}\")\n",
    "print(f\"  noise_std: {noise_std:.1f} MW\")\n",
    "print(f\"  per-instance scenario spread (mean std): \"\n",
    "      f\"{training_scenarios.sum(axis=2).std(axis=1).mean():.1f} MW\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 30,
   "id": "8f3c87ad",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "SPO+ training subset: 480 / 84044 samples (0.6%)\n",
      "  Samples per hour: ~20\n",
      "  Hour coverage: 24 hours\n",
      "  LP solves per epoch: 960\n"
     ]
    }
   ],
   "source": [
    "# =============================================================================\n",
    "# Subsample training data for SPO+ training\n",
    "#\n",
    "# 5-minute data has extreme temporal redundancy — consecutive samples are\n",
    "# nearly identical.  SPO+ needs LP solves per sample, so we stratified-sample\n",
    "# ~1000 representative instances that cover the full range of operating\n",
    "# conditions while keeping training feasible.\n",
    "# =============================================================================\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "N_SPO_SAMPLES = 500\n",
    "RNG_SUB = np.random.default_rng(99)\n",
    "\n",
    "# Stratify by hour-of-day so peak and off-peak are equally represented\n",
    "hours_tr = pd.DatetimeIndex(train_data.index).hour\n",
    "unique_hours = np.unique(hours_tr)\n",
    "samples_per_hour = max(1, N_SPO_SAMPLES // len(unique_hours))\n",
    "\n",
    "sub_idx = []\n",
    "for h in unique_hours:\n",
    "    mask = np.where(hours_tr == h)[0]\n",
    "    n_pick = min(samples_per_hour, len(mask))\n",
    "    sub_idx.extend(RNG_SUB.choice(mask, size=n_pick, replace=False).tolist())\n",
    "\n",
    "# Shuffle and trim to target size\n",
    "RNG_SUB.shuffle(sub_idx)\n",
    "sub_idx = sorted(sub_idx[:N_SPO_SAMPLES])\n",
    "\n",
    "X_tr_spo     = X_tr[sub_idx]\n",
    "y_tr_spo     = y_tr[sub_idx]\n",
    "offset_spo   = mw_offset_per_t_train[sub_idx]\n",
    "scen_spo     = training_scenarios[sub_idx]\n",
    "\n",
    "print(f\"SPO+ training subset: {len(sub_idx)} / {len(X_tr)} samples \"\n",
    "      f\"({100*len(sub_idx)/len(X_tr):.1f}%)\")\n",
    "print(f\"  Samples per hour: ~{samples_per_hour}\")\n",
    "print(f\"  Hour coverage: {len(unique_hours)} hours\")\n",
    "print(f\"  LP solves per epoch: {2 * len(sub_idx):,}\")"
   ]
  },
