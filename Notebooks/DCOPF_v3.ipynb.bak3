   "source": [
    "# =============================================================================\n",
    "# Phase 5 — Sweep a fixed α over the same eval_positions used in Phase 2.\n",
    "#\n",
    "# For each candidate α, run the full PtO pipeline (solve + realized cost)\n",
    "# at every evaluation timestep and record the average realized cost.\n",
    "# =============================================================================\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from tqdm import tqdm\n",
    "\n",
    "ALPHA_CANDIDATES = np.linspace(0.90, 1.10, 21)   # same grid as Phase 4\n",
    "N_SCENARIOS_P5   = 100\n",
    "RNG_SEED_P5      = 42\n",
    "\n",
    "alpha_participation = Pg_max / Pg_max.sum()\n",
    "\n",
    "print(f\"Sweeping {len(ALPHA_CANDIDATES)} fixed α values over {len(eval_positions)} timesteps\")\n",
    "print(f\"Total LP solves: {len(ALPHA_CANDIDATES) * len(eval_positions):,}\\n\")\n",
    "\n",
    "# --- Pre-generate forecasts and scenarios (reuse across α values) ---\n",
    "print(\"Pre-computing forecasts and scenarios for all timesteps...\")\n",
    "cached = {}\n",
    "rng_p5 = np.random.default_rng(RNG_SEED_P5)\n",
    "for t_pos in eval_positions:\n",
    "    cached[t_pos] = {\n",
    "        \"Pd_hat\":    pgbm_forecast_at(t_pos),\n",
    "        \"scenarios\": sample_pgbm_scenarios(t_pos, N_SCENARIOS_P5, rng_p5),\n",
    "        \"actual\":    pgbm_actual_at(t_pos),\n",
    "    }\n",
    "print(f\"Cached {len(cached)} timesteps.\\n\")\n",
    "\n",
    "# --- Sweep ---\n",
    "sweep_results = []\n",
    "\n",
    "for alpha_val in tqdm(ALPHA_CANDIDATES, desc=\"Fixed-α sweep\"):\n",
    "    costs      = []\n",
    "    sheds      = []\n",
    "    viols      = []\n",
    "    n_failed   = 0\n",
    "\n",
    "    for t_pos in eval_positions:\n",
    "        try:\n",
    "            c = cached[t_pos]\n",
    "            Pd_scaled = alpha_val * c[\"Pd_hat\"]\n",
    "\n",
    "            res = build_and_solve_fixed_alpha(\n",
    "                Pd_scaled, c[\"scenarios\"], alpha_participation, verbose=False\n",
    "            )\n",
    "            rlz = realized_cost(res[\"Pg\"], alpha_participation, c[\"actual\"], Pd_scaled)\n",
    "\n",
    "            costs.append(rlz[\"total\"])\n",
    "            sheds.append(rlz[\"shed\"])\n",
    "            viols.append(rlz[\"limit_viol\"])\n",
    "        except Exception:\n",
    "            n_failed += 1\n",
    "\n",
    "    sweep_results.append({\n",
    "        \"alpha\":             alpha_val,\n",
    "        \"mean_realized\":     np.mean(costs) if costs else np.inf,\n",
    "        \"median_realized\":   np.median(costs) if costs else np.inf,\n",
    "        \"mean_shed\":         np.mean(sheds) if sheds else np.inf,\n",
    "        \"mean_viol\":         np.mean(viols) if viols else np.inf,\n",
    "        \"n_solved\":          len(costs),\n",
    "        \"n_failed\":          n_failed,\n",
    "    })\n",
    "\n",
    "df_sweep = pd.DataFrame(sweep_results)\n",
    "\n",
    "# --- Find best α ---\n",
    "best_row   = df_sweep.loc[df_sweep[\"mean_realized\"].idxmin()]\n",
    "alpha_best = best_row[\"alpha\"]\n",
    "\n",
    "print(\"\\n\" + \"=\" * 70)\n",
    "print(f\"{'α':>6}  {'Mean cost ($/hr)':>16}  {'Median cost':>13}  \"\n",
    "      f\"{'Shed (MW)':>10}  {'Viol (MW)':>10}  {'Solved':>6}\")\n",
    "print(\"=\" * 70)\n",
    "for _, r in df_sweep.iterrows():\n",
    "    marker = \" <<<\" if r[\"alpha\"] == alpha_best else \"\"\n",
    "    print(f\"{r['alpha']:>6.3f}  {r['mean_realized']:>16,.2f}  \"\n",
    "          f\"{r['median_realized']:>13,.2f}  {r['mean_shed']:>10,.2f}  \"\n",
    "          f\"{r['mean_viol']:>10,.2f}  {r['n_solved']:>6}{marker}\")\n",
    "print(\"=\" * 70)\n",
    "print(f\"\\nBest fixed α = {alpha_best:.3f}  →  mean realized cost = ${best_row['mean_realized']:,.2f}/hr\")"
   ]
  },
