   "source": [
    "### 5.3 Grand Comparison: Phases 2 / 3 / 4 / 5"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 50,
   "id": "671613a8",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Shared timesteps: 200\n",
      "\n",
      "==========================================================================================================================\n",
      "  Metric                                Ph.2 (α=1)     Ph.3 (NN+SPO)    Ph.5 (α=0.950)    Ph.4 (smart α)  Ph.6 (SPO++PGBM)\n",
      "==========================================================================================================================\n",
      "  Forecast MAE (MW)                        10.93 *           13.25            200.13             10.93             55.78  \n",
      "  Forecast bias (MW)                        1.29             -3.02           -200.13 *            1.29            -18.91  \n",
      "  E[SP cost] ($/hr)                   118,178.53        120,740.09         94,294.10 *      118,063.25        115,442.51  \n",
      "  E[realized cost] ($/hr)              95,563.82        100,416.52         92,812.86 *       95,678.52         95,701.29  \n",
      "  Calibration gap ($/hr)              -22,614.71 *      -20,323.57         -1,481.24        -22,384.73        -19,741.22  \n",
      "  Avg load shed (MW)                        0.25              0.28              0.00 *            0.26              0.22  \n",
      "  Avg limit viol (MW)                       0.22              0.71              0.19 *            0.22              0.20  \n",
      "==========================================================================================================================\n",
      "  * = best across phases\n",
      "\n",
      "Ph.4 (smart α) vs Ph.5 (fixed α=0.950):\n",
      "  Smart α wins: 118/200  |  Fixed α wins: 82/200  |  Ties: 0\n",
      "  Mean advantage of smart α: $-2,865.67/hr\n",
      "\n",
      "Ph.6 (SPO++PGBM) vs Ph.2 (α=1, MSE):\n",
      "  SPO+ wins: 77/200  |  MSE wins: 122/200\n",
      "  Mean advantage of SPO+: $-137.47/hr\n"
     ]
    }
   ],
   "source": [
    "# =============================================================================\n",
    "# Head-to-head comparison across all phases on shared timesteps.\n",
    "# Phase 2: PGBM, α=1\n",
    "# Phase 3: NN + SPO  (if available)\n",
    "# Phase 4: PGBM, smart covariate-dependent α(t)\n",
    "# Phase 5: PGBM, best fixed α\n",
    "# Phase 6: SPO+ NN forecast + PGBM scenarios, α=1\n",
    "# =============================================================================\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# --- Build comparison dataframe ---\n",
    "base = results_pgbm[[\"t_pos\", \"timestamp\", \"hour\", \"actual_mw\"]].copy()\n",
    "\n",
    "def attach(df_results, prefix, base_df):\n",
    "    cols = {\n",
    "        \"realized_total\": f\"{prefix}_realized\",\n",
    "        \"sp_expected_cost\": f\"{prefix}_sp_cost\",\n",
    "        \"realized_shed\": f\"{prefix}_shed\",\n",
    "        \"limit_viol_mw\": f\"{prefix}_viol\",\n",
    "        \"forecast_error\": f\"{prefix}_err\",\n",
    "    }\n",
    "    sub = df_results[[\"t_pos\"] + list(cols.keys())].rename(columns=cols)\n",
    "    return base_df.merge(sub, on=\"t_pos\", how=\"inner\")\n",
    "\n",
    "grand = attach(results_pgbm, \"p2\", base)\n",
    "grand = attach(results_p4,   \"p4\", grand)\n",
    "grand = attach(results_p5,   \"p5\", grand)\n",
    "\n",
    "has_p3 = \"results_nn\" in dir() and results_nn is not None\n",
    "if has_p3:\n",
    "    grand = attach(results_nn, \"p3\", grand)\n",
    "\n",
    "has_p6 = \"results_p6\" in dir() and results_p6 is not None\n",
    "if has_p6:\n",
    "    grand = attach(results_p6, \"p6\", grand)\n",
    "\n",
    "print(f\"Shared timesteps: {len(grand)}\")\n",
    "\n",
    "# --- Summary table ---\n",
    "phases   = [\"Ph.2 (α=1)\", f\"Ph.5 (α={alpha_best:.3f})\", \"Ph.4 (smart α)\"]\n",
    "prefixes = [\"p2\", \"p5\", \"p4\"]\n",
    "if has_p3:\n",
    "    phases.insert(1, \"Ph.3 (NN+SPO)\")\n",
    "    prefixes.insert(1, \"p3\")\n",
    "if has_p6:\n",
    "    phases.append(\"Ph.6 (SPO++PGBM)\")\n",
    "    prefixes.append(\"p6\")\n",
    "\n",
    "metric_defs = [\n",
    "    (\"Forecast MAE (MW)\",       lambda p: grand[f\"{p}_err\"].abs().mean()),\n",
    "    (\"Forecast bias (MW)\",      lambda p: grand[f\"{p}_err\"].mean()),\n",
    "    (\"E[SP cost] ($/hr)\",       lambda p: grand[f\"{p}_sp_cost\"].mean()),\n",
    "    (\"E[realized cost] ($/hr)\", lambda p: grand[f\"{p}_realized\"].mean()),\n",
    "    (\"Calibration gap ($/hr)\",  lambda p: (grand[f\"{p}_realized\"] - grand[f\"{p}_sp_cost\"]).mean()),\n",
    "    (\"Avg load shed (MW)\",      lambda p: grand[f\"{p}_shed\"].mean()),\n",
    "    (\"Avg limit viol (MW)\",     lambda p: grand[f\"{p}_viol\"].mean()),\n",
    "]\n",
    "\n",
    "# Print\n",
    "col_w = 18\n",
    "header = f\"  {'Metric':<30}\" + \"\".join(f\"{name:>{col_w}}\" for name in phases)\n",
    "print(\"\\n\" + \"=\" * len(header))\n",
    "print(header)\n",
    "print(\"=\" * len(header))\n",
    "for mname, fn in metric_defs:\n",
    "    vals = [fn(p) for p in prefixes]\n",
    "    line = f\"  {mname:<30}\"\n",
    "    best_idx = np.argmin(vals)\n",
    "    for i, v in enumerate(vals):\n",
    "        marker = \" *\" if i == best_idx else \"  \"\n",
    "        line += f\"{v:>{col_w - 2},.2f}{marker}\"\n",
    "    print(line)\n",
    "print(\"=\" * len(header))\n",
    "print(f\"  * = best across phases\")\n",
    "\n",
    "# --- Per-timestep: Phase 4 vs Phase 5 ---\n",
    "grand[\"p4_vs_p5\"] = grand[\"p5_realized\"] - grand[\"p4_realized\"]\n",
    "n_p4_wins = (grand[\"p4_vs_p5\"] > 0).sum()\n",
    "n_p5_wins = (grand[\"p4_vs_p5\"] < 0).sum()\n",
    "n_ties    = (grand[\"p4_vs_p5\"] == 0).sum()\n",
    "print(f\"\\nPh.4 (smart α) vs Ph.5 (fixed α={alpha_best:.3f}):\")\n",
    "print(f\"  Smart α wins: {n_p4_wins}/{len(grand)}  |  \"\n",
    "      f\"Fixed α wins: {n_p5_wins}/{len(grand)}  |  Ties: {n_ties}\")\n",
    "print(f\"  Mean advantage of smart α: ${grand['p4_vs_p5'].mean():,.2f}/hr\")\n",
    "\n",
    "# --- Per-timestep: Phase 6 vs Phase 2 (SPO+ gain) ---\n",
    "if has_p6:\n",
    "    grand[\"p6_vs_p2\"] = grand[\"p2_realized\"] - grand[\"p6_realized\"]\n",
    "    n_p6_wins = (grand[\"p6_vs_p2\"] > 0).sum()\n",
    "    n_p2_wins = (grand[\"p6_vs_p2\"] < 0).sum()\n",
    "    print(f\"\\nPh.6 (SPO++PGBM) vs Ph.2 (α=1, MSE):\")\n",
    "    print(f\"  SPO+ wins: {n_p6_wins}/{len(grand)}  |  MSE wins: {n_p2_wins}/{len(grand)}\")\n",
    "    print(f\"  Mean advantage of SPO+: ${grand['p6_vs_p2'].mean():,.2f}/hr\")\n"
   ]
  },
