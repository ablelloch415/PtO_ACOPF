    "fig, axes = plt.subplots(1, 3, figsize=(18, 5))\n",
    "\n",
    "# (a) Mean realized cost vs α\n",
    "axes[0].plot(df_sweep[\"alpha\"], df_sweep[\"mean_realized\"], 'o-', color=\"steelblue\")\n",
