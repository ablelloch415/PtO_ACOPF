    "# =============================================================================\n",
    "# Phase 5 — Run the full evaluation loop at the best fixed α so we have\n",
    "# per-timestep records comparable to Phases 2–4.\n",
    "# =============================================================================\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from tqdm import tqdm\n",
    "\n",
    "alpha_participation = Pg_max / Pg_max.sum()\n",
    "\n",
    "records_p5 = []\n",
    "failed_p5  = []\n",
    "\n",
    "print(f\"Running full evaluation with fixed α = {alpha_best:.3f}\")\n",
    "\n",
    "for t_pos in tqdm(eval_positions, desc=f\"Phase 5 (α={alpha_best:.3f})\"):\n",
    "    try:\n",
    "        c = cached[t_pos]\n",
    "        Pd_scaled = alpha_best * c[\"Pd_hat\"]\n",
    "\n",
    "        res = build_and_solve_fixed_alpha(\n",
    "            Pd_scaled, c[\"scenarios\"], alpha_participation, verbose=False\n",
    "        )\n",
    "        rlz = realized_cost(res[\"Pg\"], alpha_participation, c[\"actual\"], Pd_scaled)\n",
    "\n",
    "        records_p5.append({\n",
    "            \"t_pos\":             int(t_pos),\n",
    "            \"timestamp\":         idx_te[t_pos],\n",
    "            \"hour\":              idx_te[t_pos].hour,\n",
    "            \"dow\":               idx_te[t_pos].dayofweek,\n",
    "            \"alpha_used\":        alpha_best,\n",
    "            \"scaled_mw\":         float(Pd_scaled.sum()),\n",
    "            \"pgbm_mw\":           float(c[\"Pd_hat\"].sum()),\n",
    "            \"actual_mw\":         float(c[\"actual\"].sum()),\n",
    "            \"forecast_error\":    float(Pd_scaled.sum() - c[\"actual\"].sum()),\n",
    "            \"sp_expected_cost\":  res[\"total_cost\"],\n",
    "            \"sp_stage1_cost\":    res[\"stage1_cost\"],\n",
    "            \"Pg_total\":          float(res[\"Pg\"].sum()),\n",
    "            \"realized_total\":    rlz[\"total\"],\n",
    "            \"realized_delta\":    rlz[\"delta\"],\n",
    "            \"realized_shed\":     rlz[\"shed\"],\n",
    "            \"limit_viol_mw\":     rlz[\"limit_viol\"],\n",
    "        })\n",
    "    except Exception as e:\n",
    "        failed_p5.append((int(t_pos), str(e)))\n",
    "\n",
    "results_p5 = pd.DataFrame(records_p5)\n",
    "print(f\"\\nSolved: {len(results_p5)}/{len(eval_positions)}   Failed: {len(failed_p5)}\")"
   ]
