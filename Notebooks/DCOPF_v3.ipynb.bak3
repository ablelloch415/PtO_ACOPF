  {
   "cell_type": "markdown",
   "id": "c45e8570",
   "metadata": {},
   "source": [
    "## Phase 4: Smart Scaling Factor (Covariate-Dependent α)\n",
    "\n",
    "**Idea:** Instead of feeding the raw PGBM point forecast `Pd_hat` into the stochastic DC-OPF, feed `α · Pd_hat` where `α` is chosen by a lightweight GBR model conditioned on the same covariate vector used by the PGBM. The cost-minimizing bias depends on operating conditions — overpredicting may be cheap when generators have headroom, but catastrophic near peak load.\n",
    "\n",
    "**Steps:**\n",
    "1. Grid-search the cost-minimizing `α*(t)` for each evaluation timestep\n",
    "2. Train a Gradient Boosted Regressor: covariates → `α*`\n",
    "3. Re-run the PtO pipeline with the predicted `α(t)` scaling\n",
    "4. Compare head-to-head against Phase 2 (α=1) and Phase 3 (NN+SPO)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "64972ce0",
   "metadata": {},
   "source": [
    "### 4.1 Generate Training Labels α*(t) via Grid Search over Realized Cost"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 33,
   "id": "c4e724a1",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Grid search over 21 α values × 200 timesteps\n",
      "α range: [0.90, 1.10]\n",
      "Total LP solves: 4,200\n"
     ]
    },
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "Grid search for α*: 100%|██████████| 200/200 [49:08<00:00, 14.74s/it]"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "\n",
      "Completed: 200/200   Failed: 0\n",
      "\n",
      "α* distribution:\n",
      "count    200.0000\n",
      "mean       0.9985\n",
      "std        0.0122\n",
      "min        0.9000\n",
      "25%        1.0000\n",
      "50%        1.0000\n",
      "75%        1.0000\n",
      "max        1.0000\n",
      "Name: alpha_star, dtype: float64\n",
      "\n",
      "SP expected cost improvement over α=1: $464.06/hr\n",
      "Realized   cost improvement over α=1: $13.64/hr\n",
      "Timesteps where α*≠1.0:   3/200\n"
     ]
    },
    {
     "name": "stderr",
     "output_type": "stream",
     "text": [
      "\n"
     ]
    }
   ],
   "source": [
    "# =============================================================================\n",
    "# Phase 4 — Step 1: Find the cost-minimising participation scalar α* for each\n",
    "#                    evaluation timestep.\n",
    "#\n",
    "# For each t in eval_positions:\n",
    "#   - sweep α over a grid [0.90 … 1.10]\n",
    "#   - solve the stochastic DC-OPF with participation_t = α · (Pg_max/∑Pg_max)\n",
    "#     and the UNSCALED Pd_hat\n",
    "#   - record α*(t) = argmin_α  SP_expected_cost(α, t)\n",
    "#\n",
    "# WHY use SP expected cost (not realized_cost) as the objective?\n",
    "#   The simplified realized_cost function charges\n",
    "#       response_c = (c1 @ alpha) · |delta|\n",
    "#   which decreases monotonically as sum(alpha) shrinks. This creates a\n",
    "#   degenerate incentive: lower alpha always looks \"cheaper\" when |delta| is\n",
    "#   small, regardless of the resulting load-shed risk. The LP's own expected\n",
    "#   cost is a proper scoring rule: it correctly prices the extra load-shed\n",
    "#   slacks that appear when generators absorb less imbalance (α < 1), so\n",
    "#   there is a genuine interior optimum in [0.90, 1.10] at each timestep.\n",
    "#\n",
    "# Interpretation of α:\n",
    "#   α = 1.0  →  pro-rata participation; generators cover all imbalance\n",
    "#   α < 1.0  →  generators absorb a fraction; slacks cover the rest (costly)\n",
    "#   α > 1.0  →  generators over-respond (risk hitting gen limits, also costly)\n",
    "# =============================================================================\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "from tqdm import tqdm\n",
    "\n",
    "# --- Config ---\n",
    "ALPHA_GRID     = np.linspace(0.90, 1.10, 21)\n",
    "N_SCENARIOS_P4 = 100\n",
    "RNG_SEED_P4    = 42\n",
    "\n",
    "base_participation = Pg_max / Pg_max.sum()   # capacity-weighted, sums to 1\n",
    "rng_p4 = np.random.default_rng(RNG_SEED_P4)\n",
    "\n",
    "print(f\"Grid search over {len(ALPHA_GRID)} α values × {len(eval_positions)} timesteps\")\n",
    "print(f\"α range: [{ALPHA_GRID[0]:.2f}, {ALPHA_GRID[-1]:.2f}]\")\n",
    "print(f\"Total LP solves: {len(ALPHA_GRID) * len(eval_positions):,}\")\n",
    "\n",
    "# --- Main grid search ---\n",
    "alpha_star_records = []\n",
    "grid_failed = []\n",
    "\n",
    "for t_pos in tqdm(eval_positions, desc=\"Grid search for α*\"):\n",
    "    try:\n",
    "        Pd_hat_t    = pgbm_forecast_at(t_pos)\n",
    "        scenarios_t = sample_pgbm_scenarios(t_pos, N_SCENARIOS_P4, rng_p4)\n",
    "        actual_Pd_t = pgbm_actual_at(t_pos)\n",
    "\n",
    "        best_alpha    = 1.0\n",
    "        best_sp_cost  = np.inf\n",
    "\n",
    "        for alpha_val in ALPHA_GRID:\n",
    "            participation_t = alpha_val * base_participation  # sum = alpha_val\n",
    "\n",
    "            res = build_and_solve_fixed_alpha(\n",
    "                Pd_hat_t, scenarios_t, participation_t, verbose=False\n",
    "            )\n",
    "            # Objective: SP expected cost (proper tradeoff: response vs shed)\n",
    "            if res[\"total_cost\"] < best_sp_cost:\n",
    "                best_sp_cost = res[\"total_cost\"]\n",
    "                best_alpha   = alpha_val\n",
    "\n",
    "        # Baseline: α = 1.0\n",
    "        res_base  = build_and_solve_fixed_alpha(\n",
    "            Pd_hat_t, scenarios_t, base_participation, verbose=False\n",
    "        )\n",
    "        rlz_base  = realized_cost(res_base[\"Pg\"], base_participation, actual_Pd_t, Pd_hat_t)\n",
    "\n",
    "        # Realized cost at the chosen α* (for post-hoc comparison)\n",
    "        res_star  = build_and_solve_fixed_alpha(\n",
    "            Pd_hat_t, scenarios_t, best_alpha * base_participation, verbose=False\n",
    "        )\n",
    "        rlz_star  = realized_cost(res_star[\"Pg\"], best_alpha * base_participation,\n",
    "                                  actual_Pd_t, Pd_hat_t)\n",
    "\n",
    "        alpha_star_records.append({\n",
    "            \"t_pos\":              int(t_pos),\n",
    "            \"alpha_star\":         best_alpha,\n",
    "            # SP expected cost comparison (primary optimisation target)\n",
    "            \"sp_cost_at_star\":    best_sp_cost,\n",
    "            \"sp_cost_at_1\":       res_base[\"total_cost\"],\n",
    "            \"sp_improvement\":     res_base[\"total_cost\"] - best_sp_cost,\n",
    "            # Realized cost comparison (secondary / evaluation metric)\n",
    "            \"rlz_cost_at_star\":   rlz_star[\"total\"],\n",
    "            \"rlz_cost_at_1\":      rlz_base[\"total\"],\n",
    "            \"rlz_improvement\":    rlz_base[\"total\"] - rlz_star[\"total\"],\n",
    "            \"forecast_mw\":        float(Pd_hat_t.sum()),\n",
    "            \"actual_mw\":          float(actual_Pd_t.sum()),\n",
    "        })\n",
    "    except Exception as e:\n",
    "        grid_failed.append((int(t_pos), str(e)))\n",
    "\n",
    "df_alpha = pd.DataFrame(alpha_star_records)\n",
    "\n",
    "print(f\"\\nCompleted: {len(df_alpha)}/{len(eval_positions)}   Failed: {len(grid_failed)}\")\n",
    "if grid_failed:\n",
    "    print(\"First 3 failures:\", grid_failed[:3])\n",
    "\n",
    "print(f\"\\nα* distribution:\")\n",
    "print(df_alpha[\"alpha_star\"].describe().round(4))\n",
    "\n",
    "print(f\"\\nSP expected cost improvement over α=1: ${df_alpha['sp_improvement'].mean():,.2f}/hr\")\n",
    "print(f\"Realized   cost improvement over α=1: ${df_alpha['rlz_improvement'].mean():,.2f}/hr\")\n",
    "print(f\"Timesteps where α*≠1.0:   {(df_alpha['alpha_star'] != 1.0).sum()}/{len(df_alpha)}\")\n"
   ]
  },
