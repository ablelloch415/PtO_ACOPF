    "# =============================================================================\n",
    "# α-model diagnostics: partial dependence + predicted vs actual\n",
    "# =============================================================================\n",
    "import matplotlib.pyplot as plt\n",
    "from sklearn.inspection import PartialDependenceDisplay\n",
    "\n",
    "fig, axes = plt.subplots(1, 3, figsize=(18, 5))\n",
    "\n",
    "# (a) Predicted vs actual α* (held-out test)\n",
    "axes[0].scatter(y_alpha_te, y_pred_te, s=20, alpha=0.6, label=\"test\")\n",
    "axes[0].scatter(y_alpha_tr, y_pred_tr, s=10, alpha=0.3, label=\"train\", color=\"gray\")\n",
    "lo, hi = min(y_alpha.min(), 0.90), max(y_alpha.max(), 1.10)\n",
    "axes[0].plot([lo, hi], [lo, hi], 'r--')\n",
    "axes[0].set_xlabel(\"Actual α*\")\n",
    "axes[0].set_ylabel(\"Predicted α\")\n",
    "axes[0].set_title(\"α-model: predicted vs actual\")\n",
    "axes[0].legend()\n",
    "\n",
    "# (b) Feature importance bar chart\n",
    "importances.plot.barh(ax=axes[1], color=\"steelblue\", edgecolor=\"black\")\n",
    "axes[1].set_xlabel(\"Importance\")\n",
    "axes[1].set_title(\"α-model feature importances\")\n",
    "axes[1].invert_yaxis()\n",
    "\n",
    "# (c) Residual distribution\n",
    "resid_te = y_alpha_te - y_pred_te\n",
    "axes[2].hist(resid_te, bins=25, edgecolor='black', alpha=0.7)\n",
    "axes[2].axvline(0, color='red', linestyle='--')\n",
    "axes[2].set_xlabel(\"Residual (actual α* − predicted α)\")\n",
    "axes[2].set_ylabel(\"Count\")\n",
    "axes[2].set_title(f\"Test residuals (mean={resid_te.mean():.4f}, std={resid_te.std():.4f})\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n",
    "# Partial dependence for top 3 features\n",
    "top3 = importances.index[:3].tolist()\n",
    "top3_idx = [feature_names_alpha.index(f) for f in top3]\n",
    "fig2, ax2 = plt.subplots(1, 3, figsize=(18, 5))\n",
    "PartialDependenceDisplay.from_estimator(\n",
    "    alpha_model, X_alpha_tr, features=top3_idx,\n",
    "    feature_names=feature_names_alpha, ax=ax2,\n",
    "    kind=\"average\"\n",
    ")\n",
    "fig2.suptitle(\"Partial Dependence of α on Top-3 Features\", fontsize=13)\n",
    "plt.tight_layout()\n",
    "plt.show()"
   ]
  },
